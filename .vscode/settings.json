{
  // Code Quality
  "editor.formatOnSave": false,
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "always",
    "source.fixAll.eslint": "always",
    "source.organizeImports": "never"
  },
  "oxc.typeAware": true,
  "eslint.runtime": "bun",
  "eslint.execArgv": ["-b"],
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "vue",
    "html",
    "markdown",
    "json",
    "jsonc",
    "yaml",
    "toml",
    "xml",
    "css",
    "postcss",
    "scss",
    "sass",
    "less"
  ],

  // JavaScript / TypeScript
  "js/ts.tsdk.path": "node_modules\\typescript\\lib",
  "js/ts.preferences.autoImportFileExcludePatterns": [
    "**/node_modules/vue-router/dist/**"
  ],

  // I18n Ally
  "i18n-ally.sourceLanguage": "en-US",
  "i18n-ally.keystyle": "nested",
  "i18n-ally.localesPaths": [
    "./i18n/locales"
  ],

  // Rest client
  // See https://github.com/Huachao/vscode-restclient/blob/master/README.md for details
  "rest-client.environmentVariables": {
    "$shared": {
      // Your shared environment variables
    },
    "dev": {
      // Your development environment variables
    },
    "prod": {
      // Your production environment variables
    }
  }
}
