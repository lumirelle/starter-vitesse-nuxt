amends "package://github.com/jdx/hk/releases/download/v1.46.0/hk@1.46.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.46.0/hk@1.46.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
  // Configurations
  ["stylua"] = (Builtins.stylua) {
    glob = List("**/*.lua")
  }
  ["pkl"] = (Builtins.pkl) {
    glob = List("**/*.pkl")
    check = "pkl eval {{files}}"
  }
  ["pkl-format"] = (Builtins.pkl_format) {
    glob = List("**/*.pkl")
    shell = null
    check_list_files = "pkl format --diff-name-only {{ files }}"
    fix = "pkl format --write {{ files }}"
  }

  // Source code
  ["oxlint"] = Builtins.ox_lint
  ["eslint"] = (Builtins.eslint) {
    batch = false
    glob =
      List(
        // JS & TS
        "*.js",
        "*.mjs",
        "*.cjs",
        "*.jsx",
        "*.ts",
        "*.mts",
        "*.cts",
        "*.tsx",
        // Markdown
        "*.md",
        "*.mdc",
        "*.mdx",
        // JSON
        "*.json",
        "*.jsonc",
        // YAML
        "*.yaml",
        "*.yml",
        // TOML
        "*.toml",
        // Vue
        "*.vue",
      )
    depends = List("oxlint")
  }
  ["tsc"] {
    check = "nuxt typecheck"
  }

  // Unused
  ["knip"] = (Builtins.knip) {
    check = "knip-bun --no-progress --directory {{workspace}}"
    // Disable knip auto-fix, because it's dangerous
    fix = null
  }
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = linters
  }
  ["fix"] {
    fix = true
    steps = linters
  }
  ["check"] {
    steps = linters
  }
}
