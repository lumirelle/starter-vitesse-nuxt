{
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.13",
  "scripts": {
    "prepare": "bun --parallel 'nuxt prepare' simple-git-hooks",
    "dev": "nuxt dev --open --public",
    "dev:pwa": "VITE_PLUGIN_PWA=true nuxt dev -o",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "start": "bun run .output/server/index.mjs",
    "start:generate": "bunx serve .output/public",
    "lint": "bun run --parallel oxlint eslint",
    "lint:fix": "oxlint --fix && eslint --fix",
    "typecheck": "nuxt typecheck",
    "unused": "knip-bun",
    "check": "bun run --parallel lint typecheck unused",
    "pretest": "playwright-core install --with-deps",
    "test": "vitest",
    "test:unit": "bun run test --project unit",
    "test:e2e": "bun run test --project e2e",
    "test:nuxt": "bun run test --project nuxt"
  },
  "workspaces": {
    "catalogs": {
      "frontend": {
        "@antfu/utils": "^9.3.0",
        "@takumi-rs/core": "^1.1.2",
        "@vueuse/core": "^14.2.1",
        "pinia": "^3.0.4"
      },
      "icons": {
        "@iconify-json/carbon": "^1.2.20",
        "@iconify-json/twemoji": "^1.2.5",
        "@iconify/utils": "^3.1.1"
      },
      "dev": {
        "simple-git-hooks": "git+https://github.com/toplenboren/simple-git-hooks.git#7625657"
      },
      "types": {
        "typescript": "^6.0.3"
      },
      "build": {
        "@nuxt/a11y": "^1.0.0-alpha.1",
        "@nuxt/eslint": "^1.15.2",
        "@nuxt/fonts": "^0.14.0",
        "@nuxt/hints": "^1.0.3",
        "@nuxt/image": "npm:@nuxt/image-nightly@2.0.1-20260305-121439-fd87f7d",
        "@nuxt/scripts": "^1.0.2",
        "@nuxt/test-utils": "^4.0.3",
        "@nuxtjs/color-mode": "^4.0.0",
        "@nuxtjs/i18n": "^10.3.0",
        "@nuxtjs/seo": "^5.1.3",
        "@pinia/nuxt": "^0.11.3",
        "@unocss/nuxt": "^66.6.8",
        "@vite-pwa/nuxt": "^1.1.1",
        "@vueuse/nuxt": "^14.2.1",
        "nuxt": "npm:nuxt-nightly@4.4.3-29608489.ff42fe25",
        "unocss": "^66.6.8"
      },
      "check": {
        "@antfu/eslint-config": "^8.2.0",
        "@lumirelle/oxlint-config": "^0.2.2",
        "@unocss/eslint-config": "^66.6.8",
        "eslint": "^10.2.1",
        "eslint-plugin-oxlint": "^1.62.0",
        "knip": "^6.7.0",
        "nano-staged": "^1.0.2",
        "oxlint": "^1.62.0",
        "oxlint-tsgolint": "^0.22.1",
        "vue-tsc": "^3.2.7"
      },
      "test": {
        "@vitest/coverage-v8": "^4.1.5",
        "@vue/test-utils": "^2.4.9",
        "happy-dom": "^20.9.0",
        "playwright-core": "^1.59.1",
        "std-env": "^4.1.0",
        "vitest": "^4.1.5"
      }
    }
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:check",
    "@antfu/utils": "catalog:frontend",
    "@iconify-json/carbon": "catalog:icons",
    "@iconify-json/twemoji": "catalog:icons",
    "@iconify/utils": "catalog:icons",
    "@lumirelle/oxlint-config": "catalog:check",
    "@nuxt/a11y": "catalog:build",
    "@nuxt/eslint": "catalog:build",
    "@nuxt/fonts": "catalog:build",
    "@nuxt/hints": "catalog:build",
    "@nuxt/image": "catalog:build",
    "@nuxt/scripts": "catalog:build",
    "@nuxt/test-utils": "catalog:build",
    "@nuxtjs/color-mode": "catalog:build",
    "@nuxtjs/i18n": "catalog:build",
    "@nuxtjs/seo": "catalog:build",
    "@pinia/nuxt": "catalog:build",
    "@takumi-rs/core": "catalog:frontend",
    "@unocss/eslint-config": "catalog:check",
    "@unocss/nuxt": "catalog:build",
    "@vite-pwa/nuxt": "catalog:build",
    "@vitest/coverage-v8": "catalog:test",
    "@vue/test-utils": "catalog:test",
    "@vueuse/core": "catalog:frontend",
    "@vueuse/nuxt": "catalog:build",
    "eslint": "catalog:check",
    "eslint-plugin-oxlint": "catalog:check",
    "happy-dom": "catalog:test",
    "knip": "catalog:check",
    "nano-staged": "catalog:check",
    "nuxt": "catalog:build",
    "oxlint": "catalog:check",
    "oxlint-tsgolint": "catalog:check",
    "pinia": "catalog:frontend",
    "playwright-core": "catalog:test",
    "simple-git-hooks": "catalog:dev",
    "std-env": "catalog:test",
    "typescript": "catalog:types",
    "unocss": "catalog:build",
    "vitest": "catalog:test",
    "vue-tsc": "catalog:check"
  },
  "overrides": {
    "typescript": "$typescript",
    "vite": "^8.0.9"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx nano-staged"
  },
  "nano-staged": {
    "*": [
      "oxlint --no-error-on-unmatched-pattern",
      "eslint"
    ]
  }
}
